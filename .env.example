# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Project Settings → API

# Public keys — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Private key — server-side ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Session ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-random-32-plus-char-secret

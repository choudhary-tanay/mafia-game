# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Project Settings → API

# Public keys — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Private key — server-side ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Session ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-random-32-plus-char-secret


# ─── Ably (optional — primary realtime transport) ───────────────────────────
# Found at: Ably Dashboard → your app → API Keys. Server-side ONLY.
# When unset, the game automatically uses Supabase Realtime + polling instead.
# ABLY_API_KEY=your-ably-api-key-here

# Set to 1 on HTTPS deployments whose proxy does NOT forward x-forwarded-proto
# (direct TLS to Node, TCP-passthrough LB). Vercel/Cloudflare don't need this.
# FORCE_SECURE_COOKIES=1
ABLY_API_KEY=enwohw.i0EjJA:2XoyGPckjxwjE6AtpzaLw3G423qRisaPLAfkdSZgpZI